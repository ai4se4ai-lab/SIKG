{
  "name": "vscode-sikg",
  "displayName": "SIKG - Semantic Impact Knowledge Graph",
  "description": "Intelligently select test cases based on semantic change impact analysis with reinforcement learning",
  "version": "0.1.0",
  "publisher": "sikg",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Testing",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "testing",
    "machine learning",
    "reinforcement learning",
    "test prioritization",
    "code analysis",
    "semantic analysis",
    "knowledge graph"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sikg.analyzeChanges",
        "title": "SIKG: Analyze Changes and Prioritize Tests",
        "icon": "$(testing-run-icon)"
      },
      {
        "command": "sikg.runPrioritizedTests",
        "title": "SIKG: Run Prioritized Tests",
        "icon": "$(play)"
      },
      {
        "command": "sikg.visualizeGraph",
        "title": "SIKG: Visualize Impact Graph",
        "icon": "$(graph)"
      },
      {
        "command": "sikg.rebuildGraph",
        "title": "SIKG: Rebuild Knowledge Graph",
        "icon": "$(refresh)"
      },
      {
        "command": "sikg.showResults",
        "title": "SIKG: Show Results",
        "icon": "$(list-flat)"
      },
      {
        "command": "sikg.showLearningReport",
        "title": "SIKG: Show Learning Report",
        "icon": "$(graph-line)"
      },
      {
        "command": "sikg.resetLearning",
        "title": "SIKG: Reset Learning Data",
        "icon": "$(clear-all)"
      },
      {
        "command": "sikg.exportLearningData",
        "title": "SIKG: Export Learning Data",
        "icon": "$(export)"
      },
      {
        "command": "sikg.importLearningData",
        "title": "SIKG: Import Learning Data",
        "icon": "$(import)"
      },
      {
        "command": "sikg.diagnoseLangaugeIssues",
        "title": "SIKG: Diagnose Language Issues",
        "icon": "$(search)"
      },
      {
        "command": "sikg.fixLanguageIssues",
        "title": "SIKG: Fix Language Issues",
        "icon": "$(tools)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sikg-sidebar",
          "title": "SIKG",
          "icon": "$(test-view-icon)"
        }
      ]
    },
    "views": {
      "sikg-sidebar": [
        {
          "id": "sikgView",
          "name": "Test Impact Analysis",
          "type": "webview",
          "icon": "$(test-view-icon)"
        },
        {
          "id": "sikgLearningView",
          "name": "Learning Progress",
          "type": "webview",
          "icon": "$(graph-line)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sikg.analyzeChanges",
          "when": "view == sikgView",
          "group": "navigation"
        },
        {
          "command": "sikg.runPrioritizedTests",
          "when": "view == sikgView",
          "group": "navigation"
        },
        {
          "command": "sikg.showLearningReport",
          "when": "view == sikgLearningView",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "sikg.diagnoseLangaugeIssues",
          "when": "true"
        },
        {
          "command": "sikg.fixLanguageIssues",
          "when": "true"
        },
        {
          "command": "sikg.showLearningReport",
          "when": "true"
        },
        {
          "command": "sikg.resetLearning",
          "when": "true"
        },
        {
          "command": "sikg.exportLearningData",
          "when": "true"
        },
        {
          "command": "sikg.importLearningData",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "SIKG Configuration",
      "properties": {
        "sikg.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "Log level for the extension"
        },
        "sikg.analyzeOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically analyze changes when a file is saved"
        },
        "sikg.codeFileExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "py",
            "js",
            "jsx",
            "ts",
            "tsx",
            "java",
            "cs",
            "go"
          ],
          "description": "File extensions to consider as code files (without the dot)"
        },
        "sikg.testFilePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/test_*.py",
            "**/*_test.py",
            "**/tests.py",
            "**/test*.py",
            "**/*.test.js",
            "**/*.test.ts",
            "**/*.test.jsx",
            "**/*.test.tsx",
            "**/*.spec.js",
            "**/*.spec.ts",
            "**/*.spec.jsx",
            "**/*.spec.tsx",
            "**/*Test.java",
            "**/*Tests.java",
            "**/Test*.java",
            "**/*Test.cs",
            "**/*Tests.cs",
            "**/Test*.cs",
            "**/*_test.go"
          ],
          "description": "Glob patterns to identify test files"
        },
        "sikg.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/build/**",
            "**/coverage/**",
            "**/.git/**",
            "**/venv/**",
            "**/env/**",
            "**/__pycache__/**",
            "**/target/**",
            "**/bin/**",
            "**/obj/**",
            "**/vendor/**"
          ],
          "description": "Patterns to exclude from analysis"
        },
        "sikg.maxTraversalDepth": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum traversal depth for impact propagation"
        },
        "sikg.minImpactThreshold": {
          "type": "number",
          "default": 0.05,
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum impact threshold to continue propagation (0-1)"
        },
        "sikg.highImpactThreshold": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "Threshold for high impact tests (0-1)"
        },
        "sikg.lowImpactThreshold": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "Threshold for low impact tests (0-1)"
        },
        "sikg.supportedLanguages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "python",
              "javascript",
              "typescript",
              "java",
              "csharp",
              "go"
            ]
          },
          "default": [
            "python",
            "javascript",
            "typescript",
            "java",
            "csharp",
            "go"
          ],
          "description": "Programming languages supported by SIKG"
        },
        "sikg.reinforcementLearning.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable reinforcement learning for adaptive test prioritization"
        },
        "sikg.reinforcementLearning.learningRate": {
          "type": "number",
          "default": 0.01,
          "minimum": 0.001,
          "maximum": 1.0,
          "description": "Learning rate for reinforcement learning algorithm"
        },
        "sikg.reinforcementLearning.discountFactor": {
          "type": "number",
          "default": 0.95,
          "minimum": 0.1,
          "maximum": 0.99,
          "description": "Discount factor (gamma) for future rewards in MDP"
        },
        "sikg.reinforcementLearning.explorationRate": {
          "type": "number",
          "default": 0.1,
          "minimum": 0.01,
          "maximum": 0.5,
          "description": "Initial exploration rate for epsilon-greedy policy"
        },
        "sikg.reinforcementLearning.updateFrequency": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 100,
          "description": "Number of episodes between policy updates"
        },
        "sikg.reinforcementLearning.policyType": {
          "type": "string",
          "enum": [
            "epsilon-greedy",
            "ucb",
            "softmax",
            "greedy"
          ],
          "default": "epsilon-greedy",
          "description": "Policy type for action selection"
        },
        "sikg.reinforcementLearning.temperature": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.1,
          "maximum": 5.0,
          "description": "Temperature parameter for softmax policy"
        },
        "sikg.reinforcementLearning.ucbConstant": {
          "type": "number",
          "default": 2.0,
          "minimum": 0.1,
          "maximum": 10.0,
          "description": "Confidence bound constant for UCB policy"
        },
        "sikg.reinforcementLearning.weightUpdateStrategy": {
          "type": "string",
          "enum": [
            "gradient_based",
            "reward_based",
            "error_based",
            "adaptive"
          ],
          "default": "gradient_based",
          "description": "Strategy for updating graph edge weights based on feedback"
        },
        "sikg.reinforcementLearning.momentum": {
          "type": "number",
          "default": 0.9,
          "minimum": 0.0,
          "maximum": 0.99,
          "description": "Momentum factor for weight updates"
        },
        "sikg.reinforcementLearning.rewardShaping": {
          "type": "boolean",
          "default": true,
          "description": "Enable reward shaping for better learning convergence"
        },
        "sikg.reinforcementLearning.convergenceThreshold": {
          "type": "number",
          "default": 0.01,
          "minimum": 0.001,
          "maximum": 0.1,
          "description": "Variance threshold for determining convergence"
        },
        "sikg.reinforcementLearning.maxEpisodes": {
          "type": "number",
          "default": 10000,
          "minimum": 100,
          "maximum": 100000,
          "description": "Maximum number of learning episodes"
        },
        "sikg.reinforcementLearning.autoPersist": {
          "type": "boolean",
          "default": true,
          "description": "Automatically persist learning data between sessions"
        },
        "sikg.reinforcementLearning.stateFeatures": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "changeComplexity",
              "changeSemanticTypes", 
              "changeScope",
              "historicalAccuracy",
              "recentTrend",
              "failureRate",
              "testCoverage",
              "testSuiteSize",
              "averageTestTime",
              "projectSize",
              "codeChurn",
              "complexity",
              "graphDensity",
              "graphCentrality",
              "testCodeRatio",
              "timeOfDay",
              "dayOfWeek",
              "commitFrequency"
            ]
          },
          "default": [
            "changeComplexity",
            "historicalAccuracy",
            "testCoverage",
            "codeChurn",
            "graphDensity",
            "projectSize"
          ],
          "description": "State features to use for reinforcement learning"
        },
        "sikg.reinforcementLearning.rewardWeights": {
          "type": "object",
          "properties": {
            "accuracy": {
              "type": "number",
              "default": 0.2,
              "minimum": 0,
              "maximum": 1
            },
            "precision": {
              "type": "number", 
              "default": 0.2,
              "minimum": 0,
              "maximum": 1
            },
            "recall": {
              "type": "number",
              "default": 0.2, 
              "minimum": 0,
              "maximum": 1
            },
            "f1Score": {
              "type": "number",
              "default": 0.3,
              "minimum": 0,
              "maximum": 1
            },
            "efficiency": {
              "type": "number",
              "default": 0.1,
              "minimum": 0,
              "maximum": 1
            },
            "falsePositivePenalty": {
              "type": "number",
              "default": 0.3,
              "minimum": 0,
              "maximum": 1
            },
            "falseNegativePenalty": {
              "type": "number",
              "default": 0.4,
              "minimum": 0,
              "maximum": 1
            }
          },
          "default": {
            "accuracy": 0.2,
            "precision": 0.2,
            "recall": 0.2,
            "f1Score": 0.3,
            "efficiency": 0.1,
            "falsePositivePenalty": 0.3,
            "falseNegativePenalty": 0.4
          },
          "description": "Weights for different components of the reward function"
        },
        "sikg.reinforcementLearning.relationshipWeights": {
          "type": "object",
          "properties": {
            "CALLS": {
              "type": "number",
              "default": 0.9,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "USES": {
              "type": "number",
              "default": 0.8,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "INHERITS_FROM": {
              "type": "number",
              "default": 0.9,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "DEPENDS_ON": {
              "type": "number",
              "default": 0.7,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "BELONGS_TO": {
              "type": "number",
              "default": 0.8,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "TESTS": {
              "type": "number",
              "default": 1.0,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "IS_TESTED_BY": {
              "type": "number",
              "default": 1.0,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "MODIFIES": {
              "type": "number",
              "default": 0.9,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "IMPORTS": {
              "type": "number",
              "default": 0.6,
              "minimum": 0.1,
              "maximum": 1.0
            }
          },
          "default": {
            "CALLS": 0.9,
            "USES": 0.8,
            "INHERITS_FROM": 0.9,
            "DEPENDS_ON": 0.7,
            "BELONGS_TO": 0.8,
            "TESTS": 1.0,
            "IS_TESTED_BY": 1.0,
            "MODIFIES": 0.9,
            "IMPORTS": 0.6
          },
          "description": "Initial weights for different relationship types in the knowledge graph"
        },
        "sikg.reinforcementLearning.semanticTypeWeights": {
          "type": "object",
          "properties": {
            "BUG_FIX": {
              "type": "number",
              "default": 0.8,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "FEATURE_ADDITION": {
              "type": "number",
              "default": 0.7,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "REFACTORING_SIGNATURE": {
              "type": "number",
              "default": 0.9,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "REFACTORING_LOGIC": {
              "type": "number",
              "default": 0.5,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "DEPENDENCY_UPDATE": {
              "type": "number",
              "default": 0.6,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "PERFORMANCE_OPT": {
              "type": "number",
              "default": 0.4,
              "minimum": 0.1,
              "maximum": 1.0
            },
            "UNKNOWN": {
              "type": "number",
              "default": 0.5,
              "minimum": 0.1,
              "maximum": 1.0
            }
          },
          "default": {
            "BUG_FIX": 0.8,
            "FEATURE_ADDITION": 0.7,
            "REFACTORING_SIGNATURE": 0.9,
            "REFACTORING_LOGIC": 0.5,
            "DEPENDENCY_UPDATE": 0.6,
            "PERFORMANCE_OPT": 0.4,
            "UNKNOWN": 0.5
          },
          "description": "Initial weights for different semantic change types"
        },
        "sikg.visualizations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable graph visualizations"
        },
        "sikg.visualizations.maxNodes": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 2000,
          "description": "Maximum number of nodes to display in graph visualization"
        },
        "sikg.performance.enableCaching": {
          "type": "boolean",
          "default": true,
          "description": "Enable caching for improved performance"
        },
        "sikg.performance.maxCacheSize": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "Maximum number of items to keep in cache"
        },
        "sikg.performance.backgroundProcessing": {
          "type": "boolean",
          "default": true,
          "description": "Enable background processing for graph building and analysis"
        },
        "sikg.experimental.features": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "multiObjectiveOptimization",
              "transferLearning", 
              "onlineLearning",
              "advancedFeatureExtraction",
              "crossProjectLearning"
            ]
          },
          "default": [],
          "description": "Enable experimental features (use with caution)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.70.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.19.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "crypto": "^1.0.1",
    "d3": "^7.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/vscode-sikg.git"
  },
  "homepage": "https://github.com/your-org/vscode-sikg#readme",
  "bugs": {
    "url": "https://github.com/your-org/vscode-sikg/issues"
  },
  "license": "MIT",
  "icon": "images/sikg-icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  }
}